# ── CA Fashion CRM — Environment Variables ──────────────────────────────────
# Copy this file to .env.local (for local dev) or set these in your
# ECS task definition / GitHub Actions secrets for production.

# PostgreSQL connection string
# Local Docker Compose:
DATABASE_URL=postgresql://cafashion:localdev123@localhost:5432/cafashion_crm
# Production RDS example:
# DATABASE_URL=postgresql://cafashion:<password>@ca-fashion-crm.xxxx.eu-west-2.rds.amazonaws.com:5432/cafashion_crm

# Node environment
NODE_ENV=development

# Server port (Next.js default)
PORT=3000
